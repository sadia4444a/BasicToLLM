# .gitignore for Voice Cloning Project

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# Model cache (optional - uncomment if you don't want to track large model files)
# *.bin
# *.safetensors
# *.onnx

# Output files (optional - uncomment if you want to track output)
# output/*.wav

# Large files
*.mp4
*.avi
*.mov
*.mkv

# Logs
*.log
logs/

# OS generated files
Thumbs.db
.Spotlight-V100
.Trashes
